%% Diagram: Lofn System Architecture
%% Type: Flowchart
%% Generated: 2026-03-17

flowchart TD
    client([🌐 Client / Browser])

    subgraph api["Lofn.API"]
        controllers["Controllers\n(Product, Order)"]
        startup_api["Startup\n(Auth, CORS, Swagger)"]
    end

    subgraph app["Lofn.Application"]
        di["DI Bootstrap\n(ConfigureLofn)"]
    end

    subgraph domain["Lofn.Domain"]
        services["Services\n(ProductService, OrderService)"]
        models["Models\n(Product, Order, OrderItem)"]
        core["Core\n(LogCore, Utils)"]
    end

    subgraph nuget["Lofn (NuGet Package)"]
        dto["DTO\n(Params, Results, Enums, Settings)"]
        acl["ACL\n(ProductClient, BaseClient)"]
    end

    subgraph infra_ifaces["Lofn.Infra.Interfaces"]
        repo_ifaces["Repository Interfaces\n(IOrderRepository, IProductRepository)"]
        uow_iface["IUnitOfWork"]
    end

    subgraph infra["Lofn.Infra"]
        context["LofnContext\n(EF Core 9)"]
        repos["Repositories\n(OrderRepository, ProductRepository)"]
        uow["UnitOfWork"]
    end

    subgraph external["External Services"]
        nauth["🔐 NAuth\n(Authentication)"]
        stripe["💳 Stripe\n(Payments)"]
        aws["☁️ AWS S3\n(File Storage)"]
        ztools["🔧 zTools\n(ChatGPT, Mail, Utils)"]
    end

    db[(🐘 PostgreSQL)]

    client -->|"HTTP/HTTPS"| controllers
    startup_api -->|"configures"| di
    di -->|"registers"| services
    di -->|"registers"| repos
    controllers -->|"uses"| services
    services -->|"uses"| repo_ifaces
    services -->|"uses"| dto
    services -->|"maps"| models
    infra -->|"implements"| infra_ifaces
    repos -->|"queries"| context
    context -->|"Npgsql"| db
    acl -->|"HTTP calls"| nauth
    services -->|"payments"| stripe
    services -->|"file upload"| aws
    controllers -->|"auth validation"| nauth
    acl -->|"uses"| dto

    style api fill:#4A90D9,stroke:#2C5F8A,color:#fff
    style app fill:#7B68EE,stroke:#5A4CBE,color:#fff
    style domain fill:#50C878,stroke:#3A9A5C,color:#fff
    style nuget fill:#FF8C00,stroke:#CC7000,color:#fff
    style infra_ifaces fill:#DDA0DD,stroke:#AA70AA,color:#333
    style infra fill:#CD853F,stroke:#A0682F,color:#fff
    style external fill:#FF6B6B,stroke:#CC5555,color:#fff
    style db fill:#336791,stroke:#264D6E,color:#fff
